        "\n",
        "def split(arr): return arr[idx_train], arr[idx_val], arr[idx_test]\n",
        "\n",
        "Xiq_tr, Xiq_val, Xiq_te = split(X_iq)\n",
        "Xap_tr, Xap_val, Xap_te = split(X_ap)\n",
