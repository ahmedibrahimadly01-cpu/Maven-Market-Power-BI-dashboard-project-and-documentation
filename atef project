        "import tensorflow as tf\n",
        "from tensorflow.keras import layers, Input, Model\n",
        "\n",
        "def conv_block(inp, filters=64, kernel=3):\n",
        "    x = layers.Conv1D(filters, kernel, padding='same')(inp)\n",
        "    x = layers.BatchNormalization()(x)\n",
        "    x = layers.ReLU()(x)\n",
        "    return x\n",
        "\n",
        "inp_iq = Input(shape=(128, 2), name='iq_input')\n",
        "inp_ap = Input(shape=(128, 2), name='ap_input')\n",
        "inp_i  = Input(shape=(128, 1), name='i_input')\n",
        "inp_q  = Input(shape=(128, 1), name='q_input')\n",
        "\n",
        "conv1 = conv_block(inp_iq, filters=64)\n",
        "conv2 = conv_block(inp_ap, filters=64)\n",
        "conv3 = conv_block(inp_i, filters=64)\n",
        "conv4 = conv_block(inp_q, filters=64)\n",
        "\n",
        "iq_fused = layers.Concatenate()([conv3, conv4])\n",
        "conv5 = conv_block(iq_fused, filters=64, kernel=1)\n",
        "\n",
        "fused = layers.Concatenate()([conv1, conv2, conv5])\n",
        "\n",
        "x = conv_block(fused, filters=64, kernel=3)\n",
        "x = layers.MaxPooling1D(pool_size=3, strides=3)(x)\n",
        "x = conv_block(x, filters=64, kernel=3)\n",
        "\n",
        "x = layers.Bidirectional(layers.LSTM(64, activation='tanh', return_sequences=True))(x)\n",
        "\n",
        "attn_scores = layers.Dense(1)(x)\n",
        "attn_weights = layers.Softmax(axis=1)(attn_scores)\n",
        "x = layers.Multiply()([x, attn_weights])\n",
        "x = layers.Lambda(lambda t: tf.reduce_sum(t, axis=1))(x)\n",
        "\n",
        "x = layers.Dropout(0.5)(x)\n",
        "x = layers.Flatten()(x)\n",
        "out = layers.Dense(len(mods), activation='softmax',\n",
        "                    kernel_regularizer=tf.keras.regularizers.l2(0.001))(x)\n",
        "\n",
        "qsla_model = Model(inputs=[inp_iq, inp_ap, inp_i, inp_q], outputs=out)\n",
        "qsla_model.summary()"
      ],
