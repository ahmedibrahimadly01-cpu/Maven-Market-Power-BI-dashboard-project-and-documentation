        "\n",
        "X, y = [], []\n",
        "for mod in mods:\n",
        "    for snr in snrs:\n",
        "        samples = data[(mod, snr)]\n",
        "        X.append(samples)\n",
        "        y += [mods.index(mod)] * samples.shape[0]\n",
        "\n",
        "X = np.vstack(X).astype(np.float32)   # shape: (N, 2, 128)\n",
        "y = np.array(y)\n",
        "print(\"X shape:\", X.shape, \"| y shape:\", y.shape)"
